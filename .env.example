# ── DCTII configuration (copy to .env and adjust) ────────────────────────────
# All values below are defaults baked into the code; override for your own GCP project.

# Google Cloud project that hosts BigQuery datasets + GCS model bucket
GCP_PROJECT=your-gcp-project-id

# BigQuery datasets
BQ_SERVING_DATASET=dctii_serving
BQ_REF_DATASET=dctii_ref
BQ_CURATED_DATASET=dctii_curated
BQ_STAGING_DATASET=dctii_staging

# ── API service ──────────────────────────────────────────────────────────────
# Comma-separated API keys for protected endpoints.
# Leave EMPTY for unauthenticated dev mode; set real keys (or wire Secret Manager) in prod.
DCTII_API_KEYS=
RATE_LIMIT_PER_MINUTE=100
CORS_ORIGINS=*
API_VERSION=1.1.0

# Optional: lineage tag written to the pipeline_runs table
TRIGGERED_BY=manual
